<Window x:Class="BHyveControllerApp.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="YardRelay Help"
        Width="1040"
        Height="780"
        MinWidth="760"
        MinHeight="560"
        Background="#101010"
        Foreground="#f5f5f5">
  <Grid>
    <wv2:WebView2 x:Name="HelpWebView" DefaultBackgroundColor="#101010" />

    <Border x:Name="MissingHelpPanel" Background="#101010" Padding="32" Visibility="Collapsed">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="580">
        <TextBlock Text="Help is unavailable" FontSize="24" FontWeight="SemiBold" TextAlignment="Center" />
        <TextBlock x:Name="MissingHelpText"
                   Margin="0,10,0,0"
                   Foreground="#b8b8b8"
                   TextWrapping="Wrap"
                   TextAlignment="Center" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
